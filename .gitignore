# Jupiter slurm interface
jupyter-*.out

# Python caches and local environments
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/
env/

# Local Jupyter/IPython state
.jupyter-config/
.jupyter-data/
.jupyter-runtime/
.ipython/

# Large/generated project artifacts
# data/**
# models/**
# results/**
# runs/**

# Keep lightweight placeholders or docs if we add them later
!data/**/.gitkeep
!data/**/README.md
!models/**/.gitkeep
!models/**/README.md
!results/**/.gitkeep
!results/**/README.md
!runs/**/.gitkeep
!runs/**/README.md

