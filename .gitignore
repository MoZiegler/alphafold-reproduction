*.pt
*.pth
*.ckpt
*.safetensors
*.pkl
*.pickle
*.npz
*.npy
*.h5
*.hdf5
*.parquet
*.arrow
*.fa
*.fasta
*.a3m
*.sto
*.pdb
*.cif
*.mmcif
*.sdf
*.mol2

# Archives and downloaded database chunks
*.gz
*.bz2
*.xz
*.zip
*.tar
*.tar.gz
*.tgz

# Cluster/runtime logs
*.log
*.out
*.err
slurm-*.out

# Executed/generated notebook copies
*_executed.ipynb
executed.ipynb
smoke_executed.ipynb

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Codex/agent-local state
.agents/

