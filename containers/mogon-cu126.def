Bootstrap: docker
From: nvidia/cuda:12.6.3-cudnn-devel-ubuntu22.04

%labels
    Author alphafold-reproduction
    Description CUDA 12.6 / Python 3.10 / PyTorch / RDKit / Jupyter environment for Mogon Apptainer

%environment
    export VIRTUAL_ENV=/app/.venv
    export PATH=/app/.venv/bin:/usr/local/cuda/bin:/usr/local/bin:/usr/bin:/bin
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}
    export PYTHONNOUSERSITE=1
    export MPLBACKEND=Agg
    export JUPYTER_CONFIG_DIR=/workspace/.jupyter-config
    export JUPYTER_DATA_DIR=/workspace/.jupyter-data
    export JUPYTER_RUNTIME_DIR=/workspace/.jupyter-runtime

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        g++ \
        gcc \
        hmmer \
        hhsuite \
        libxrender1 \
        libxext6 \
        libsm6 \
        mmseqs2 \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        wget
    rm -rf /var/lib/apt/lists/*

    python3 -m venv /app/.venv
    /app/.venv/bin/python -m pip install --upgrade pip setuptools wheel

    # Mirror the probed environment shape: CUDA 12.6 PyTorch inside /app/.venv.
    # If PyTorch changes its newest cu126 wheels, this remains a CUDA-12.6 build.
    /app/.venv/bin/python -m pip install --index-url https://download.pytorch.org/whl/cu126 \
        torch torchvision torchaudio

    /app/.venv/bin/python -m pip install \
        biopython \
        cython \
        ipykernel \
        ipywidgets \
        jupyterlab \
        logomaker \
        matplotlib \
        networkx \
        nglview \
        numpy \
        pandas \
        psutil \
        py3Dmol \
        pyarrow \
        pymsaviz \
        rdkit \
        requests \
        scipy \
        tqdm

    # Torch Geometric wheels are version/CUDA-specific; install them after torch
    # so pip can resolve the compatible wheel set.
    /app/.venv/bin/python -m pip install torch_geometric

    /app/.venv/bin/python -m ipykernel install \
        --prefix=/app/.venv \
        --name alphafold-repro-cu126 \
        --display-name "AlphaFold Repro CUDA 12.6"

%runscript
    exec /app/.venv/bin/python "$@"

%test
    /app/.venv/bin/python - <<'PY'
import torch
import rdkit
import torch_geometric
import Bio
print("python ok")
print("torch", torch.__version__, "cuda_build", torch.version.cuda, "cuda_available", torch.cuda.is_available())
print("rdkit", rdkit.__version__)
print("torch_geometric", torch_geometric.__version__)
print("biopython", Bio.__version__)
PY
